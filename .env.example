# campseek 설정 (복사해서 .env 로 사용: cp .env.example .env)

# 서버 포트
PORT=3000

# 감시 주기(ms). 기본 5분. 너무 짧게 두지 마세요(사이트 부하/차단 위험).
WATCH_INTERVAL_MS=300000
# 같은 감시에 대한 재알림 최소 간격(ms). 기본 1시간.
WATCH_RENOTIFY_MS=3600000
# 감시 비활성화하려면 true
# WATCH_DISABLED=true

# ---- 알림 채널 (선택) ----
# 설정하지 않으면 콘솔 로그 + 웹 UI 표시만 됩니다.

# 텔레그램: @BotFather 로 봇 생성 후 토큰, 본인 chat_id
# TELEGRAM_BOT_TOKEN=123456:ABC-...
# TELEGRAM_CHAT_ID=123456789

# 임의 웹훅 (Slack/Discord Incoming Webhook 등)
# NOTIFY_WEBHOOK_URL=https://hooks.slack.com/services/...

# ---- [옵션] 공식 공공데이터 OpenAPI (국립 휴양림 교차검증) ----
# data.go.kr "산림청_국립자연휴양림 예약정보"(15134227) 활용신청 후 발급
# FOREST_OPENAPI_KEY=디코딩된_serviceKey
# FOREST_OPENAPI_URL=승인상세페이지의_전체_요청주소
